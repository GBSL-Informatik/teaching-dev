{
    "name": "@tdev/core",
    "workspaces": [
        "packages/**",
        "."
    ],
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "docusaurus": "docusaurus",
        "start": "concurrently --raw --kill-others 'PACKAGE_SRC=packages PACKAGE_DEST=docs/Packages docusaurus start' 'sleep 1s && tsx updateSync/packageDocsSync/watch.ts --src packages --dest tdev-website/docs/packages'",
        "prebuild": "yarn workspace @tdev/material-sync sync && tsx updateSync/packageDocsSync/preBuild.ts --src packages --dest tdev-website/docs/packages",
        "build": "docusaurus build",
        "swizzle": "docusaurus swizzle",
        "deploy": "docusaurus deploy",
        "clear": "docusaurus clear",
        "serve": "docusaurus serve",
        "write-translations": "docusaurus write-translations",
        "write-heading-ids": "docusaurus write-heading-ids",
        "typecheck": "tsc",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest --coverage",
        "updateTdev": "tsx updateSync/updateTdev.ts",
        "sync": "yarn workspace @tdev/material-sync sync",
        "remove": "yarn workspace @tdev/material-sync run remove",
        "postremove": "yarn workspace @tdev/material-sync sync",
        "precleanup": "yarn workspace @tdev/material-sync restore",
        "cleanup": "yarn workspace @tdev/material-sync cleanup",
        "add": "yarn workspace @tdev/material-sync run add",
        "addClass": "yarn workspace @tdev/material-sync run addClass",
        "postadd": "yarn workspace @tdev/material-sync sync"
    },
    "dependencies": {
        "@docusaurus/core": "^3.10.1",
        "@docusaurus/faster": "^3.10.1",
        "@docusaurus/preset-classic": "^3.10.1",
        "@docusaurus/theme-classic": "^3.10.1",
        "@docusaurus/theme-common": "^3.10.1",
        "@docusaurus/theme-mermaid": "^3.10.1",
        "@mdi/js": "^7.4.47",
        "@mdi/react": "^1.6.1",
        "@mdx-js/react": "^3.1.1",
        "@mermaid-js/layout-elk": "^0.2.1",
        "@sentry/react": "^10.64.0",
        "@sentry/webpack-plugin": "^3.3.1",
        "ace-builds": "^1.43.6",
        "axios": "^1.18.1",
        "better-auth": "^1.6.23",
        "browser-image-compression": "^2.0.2",
        "clsx": "^2.1.1",
        "docusaurus-plugin-sass": "^0.2.6",
        "dotenv": "^17.4.2",
        "es-toolkit": "^1.49.0",
        "exceljs": "^4.4.0",
        "gray-matter": "^4.0.3",
        "hashery": "^3.0.0",
        "heic2any": "^0.0.4",
        "idb": "^8.0.3",
        "js-yaml": "^5.2.1",
        "known-css-properties": "^0.37.0",
        "mdast-util-gfm-footnote": "^2.1.0",
        "mdast-util-math": "^3.0.0",
        "micromark-extension-math": "^3.1.0",
        "micromatch": "^4.0.8",
        "minimist": "^1.2.8",
        "mobx": "^6.16.1",
        "mobx-react-lite": "^4.1.1",
        "mobx-utils": "^6.1.1",
        "qrcode.react": "^4.2.0",
        "quill": "^2.0.3",
        "raw-loader": "^4.0.2",
        "rc-slider": "^11.1.9",
        "react": "^19.2.7",
        "react-ace": "^14.0.1",
        "react-diff-viewer-continued": "^3.4.0",
        "react-dom": "^19.2.7",
        "react-draggable": "4.5.0",
        "react-katex": "^3.1.0",
        "react-quilljs": "^2.0.5",
        "react-select": "^5.10.2",
        "reactjs-popup": "^2.0.6",
        "rehype-katex": "^7.0.1",
        "remark-math": "^6.0.0",
        "sass": "^1.101.0",
        "socket.io-client": "^4.8.3",
        "uuid": "^14.0.1"
    },
    "devDependencies": {
        "@docusaurus/module-type-aliases": "^3.10.1",
        "@docusaurus/plugin-rsdoctor": "^3.10.1",
        "@docusaurus/tsconfig": "^3.10.1",
        "@docusaurus/types": "^3.10.1",
        "@types/exceljs": "^1.3.2",
        "@types/fs-extra": "^11.0.4",
        "@types/js-yaml": "^4.0.9",
        "@types/micromatch": "^4.0.10",
        "@types/minimist": "^1.2.5",
        "@types/react-dom": "^19.2.3",
        "@types/react-katex": "^3.0.4",
        "@types/uuid": "^11.0.0",
        "@types/wicg-file-system-access": "^2023.10.7",
        "@vitest/coverage-v8": "^4.1.10",
        "concurrently": "^10.0.3",
        "fs-extra": "^11.3.6",
        "prettier": "^3.9.4",
        "remark": "^15.0.1",
        "remark-directive": "^4.0.0",
        "remark-frontmatter": "^5.0.0",
        "tsx": "^4.22.4",
        "typescript": "^7.0.2",
        "vfile": "^6.0.3",
        "vitest": "^4.1.10",
        "yaml-loader": "^0.9.0"
    },
    "peerDependencies": {
        "react-hook-form": "*"
    },
    "browserslist": {
        "production": [
            ">0.5%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 3 chrome version",
            "last 3 firefox version",
            "last 5 safari version"
        ]
    },
    "engines": {
        "node": ">=24.13"
    }
}
