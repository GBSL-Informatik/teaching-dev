// https://github.com/facebook/docusaurus/blob/main/packages/docusaurus-tsconfig/tsconfig.json
// internalized, since the original included deprecated "baseUrl"
{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Docusaurus",
    "docs": "https://docusaurus.io/docs/typescript-support",
    "compilerOptions": {
        "allowJs": true,
        "esModuleInterop": true,
        "jsx": "preserve",
        "target": "ES2022",
        "lib": ["ES2022", "DOM"],
        "moduleResolution": "bundler",
        "module": "esnext",
        "noEmit": true,
        "paths": {
            "@site/*": ["./*"]
        },
        "skipLibCheck": true
    }
}
