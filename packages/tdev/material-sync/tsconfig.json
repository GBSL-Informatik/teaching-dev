{
    "extends": "../../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": ".",
        "module": "NodeNext",
        "declaration": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "moduleResolution": "NodeNext"
    },
    "include": ["src/*.ts", "src/helpers/resolveEditUrl.ts", "src/helpers/index.ts"],
    "exclude": ["node_modules", "dist"]
}
