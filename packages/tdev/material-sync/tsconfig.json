{
    "extends": "../../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": ".",
        "module": "commonjs",
        "declaration": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "ignoreDeprecations": "6.0",
        "moduleResolution": "node"
    },
    "include": ["src/*.ts"],
    "exclude": ["node_modules", "dist"]
}
